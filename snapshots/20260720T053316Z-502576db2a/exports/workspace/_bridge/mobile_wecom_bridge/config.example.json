{
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "public_base_url": "https://your-tunnel.example.com"
  },
  "queue": {
    "db_path": "mobile_bridge.db"
  },
  "security": {
    "allowed_users": [],
    "confirmation_secret_env": "MOBILE_BRIDGE_CONFIRM_SECRET",
    "confirmation_secret_hash": "",
    "confirmation_ttl_seconds": 300
  },
  "safety": {
    "shadow_mode": true,
    "paused": false,
    "max_input_chars": 2000
  },
  "trigger": {
    "cooldown_seconds": 10
  },
  "wecom": {
    "corp_id_env": "WECOM_CORP_ID",
    "corp_secret_env": "WECOM_CORP_SECRET",
    "agent_id": 1000002,
    "token_env": "WECOM_CALLBACK_TOKEN",
    "encoding_aes_key_env": "WECOM_ENCODING_AES_KEY"
  },
  "logging": {
    "file": "logs/wecom_bridge.log",
    "level": "INFO"
  }
}
