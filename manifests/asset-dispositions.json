{
  "schema": "codex_mirror.asset_dispositions.v1",
  "rule": "Every top-level asset in an inventoried live root must be mirrored, represented by a generated export, externally archived, reacquired, regenerated, or explicitly classified as runtime/historical. Unknown assets block refresh.",
  "roots": [
    {
      "id": "codex-home",
      "root": "${CODEX_HOME}",
      "required": true,
      "rules": [
        {
          "patterns": ["*.bak", "*.bak-*", "*.tmp-*"],
          "disposition": "historical",
          "owner": "backup_router",
          "evidence": "superseded local backup or interrupted temporary write"
        },
        {
          "patterns": ["*.sqlite-shm", "*.sqlite-wal"],
          "disposition": "runtime_companion",
          "owner": "database_owner",
          "evidence": "database sidecar is restored only with an owner-consistent database archive"
        },
        {
          "patterns": ["*.db-journal"],
          "disposition": "runtime_companion",
          "owner": "database_owner",
          "evidence": "SQLite rollback journal is a runtime companion restored only with an owner-consistent database archive"
        },
        {
          "names": [
            ".app-server-state-reconciled-v1", ".personality_migration", "cap_sid",
            "installation_id"
          ],
          "disposition": "regenerate",
          "owner": "codex_cli",
          "evidence": "machine or installation identity marker"
        },
        {
          "names": ["chrome-native-hosts-v2.json"],
          "disposition": "generated_representation",
          "owner": "runtime",
          "evidence": "runtime-versions native_host_compatibility export"
        },
        {
          "names": [
            "AGENTS.md", "MEMORY.md", "USER_WORKING_PREFERENCES.md",
            "automations", "scripts", "skills", "tools"
          ],
          "disposition": "historical",
          "owner": "wsl_workspace",
          "evidence": "WSL Work Git codex-home is the active authority; Windows Codex home copies are transition shadows and must not override the mirror source"
        },
        {
          "names": [
            ".sandbox", ".sandbox-bin", ".tmp", "ambient-suggestions", "backups_state",
            "bin", "cache", "computer-use", "diagnostics", "disabled-startup-shortcuts", "logs",
            "mcp-oauth-locks", "node_repl", "pets", "plugins", "process_manager",
            "state", "tmp", "vendor_imports", "worktrees"
          ],
          "disposition": "regenerate",
          "owner": "codex_cli",
          "evidence": "runtime, WSL CLI binary cache, derived import, process-local state, or disposable task worktree metadata"
        },
        {
          "names": [".sandbox-secrets"],
          "disposition": "reacquire",
          "owner": "secret_vault",
          "evidence": "secret-bearing sandbox state"
        },
        {
          "names": ["archived_sessions", "attachments", "generated_images", "history.jsonl", "session_index.jsonl", "visualizations"],
          "disposition": "external_archive",
          "owner": "conversation_artifact_owner",
          "evidence": "codex-conversation-and-artifact-history"
        },
        {
          "names": ["backups"],
          "disposition": "historical",
          "owner": "backup_router",
          "evidence": "backup history remains outside the capability mirror"
        },
        {
          "names": ["shell_snapshots"],
          "disposition": "historical",
          "owner": "codex_cli",
          "evidence": "captured shell environments are historical diagnostics, not live restore inputs"
        }
      ]
    },
    {
      "id": "agent-home",
      "root": "${AGENT_HOME}",
      "required": true,
      "rules": [
        {
          "names": ["backups", "skill-backups"],
          "disposition": "historical",
          "owner": "skill_lifecycle_governance",
          "evidence": "superseded compatibility skill copies"
        },
        {
          "names": ["logs"],
          "disposition": "regenerate",
          "owner": "skill_lifecycle_governance",
          "evidence": "derived usage and validation logs"
        }
      ]
    },
    {
      "id": "cc-switch-home",
      "root": "${CC_SWITCH_HOME}",
      "required": true,
      "rules": [
        {
          "names": ["backups", "skill-backups"],
          "disposition": "historical",
          "owner": "cc_switch",
          "evidence": "superseded provider or skill state"
        },
        {
          "names": ["crash.log", "logs"],
          "disposition": "regenerate",
          "owner": "cc_switch",
          "evidence": "derived operational logs"
        },
        {
          "patterns": ["*.db-journal"],
          "disposition": "runtime_companion",
          "owner": "database_owner",
          "evidence": "SQLite rollback journal is a runtime companion restored only with an owner-consistent database archive"
        }
      ]
    }
  ]
}
