    {"path": "manifests/control-plane-contract.json", "role": "static_contract"},
    {"path": "manifests/external-archives.json", "role": "static_contract"},
    {"path": "manifests/restore-order.json", "role": "static_contract"},
    {"path": "manifests/schemas/snapshot-manifest.schema.json", "role": "static_contract"},
    {"path": "manifests/secret-requirements.json", "role": "static_contract"},
    {"path": "manifests/source-authorities.json", "role": "static_contract"},
