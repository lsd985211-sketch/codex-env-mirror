{
  "schema": "mcp_recovery_bundle_manifest.v1",
  "authority": "workspace/_bridge/mcp_recovery_bundle_owner.py",
  "variables": {
    "WINDOWS_SEARCH_RUNTIME_KEY": "cp314-win_amd64"
  },
  "policy": {
    "rule": "restore requires an executable implementation or an explicit owner reacquisition/reconnect receipt",
    "public_release_assets_must_be_redistributable": true,
    "secrets_sessions_and_runtime_state_are_never_bundled": true,
    "bundle_format": "tar.gz",
    "content_addressed": true,
    "hash_algorithm": "sha256"
  },
  "bundles": [
    {
      "id": "local-mcp-hub-source",
      "capabilities": ["local-mcp-hub", "custom-slash-commands", "sqlite-scratch", "sqlite-bridge-ro", "github", "resource", "mcp-session", "workflow"],
      "implementation_type": "source_tree",
      "platform": "linux-x64",
      "license": "workspace-owned-mixed-dependencies",
      "source": "${WORK_GIT_ROOT}/workspace/_bridge",
      "include": ["*.py", "*.json", "*.toml", "*.md", "*.ps1", "*.sh", "docs/**", "policies/**", "shared/install-local-mcp-hub-task.ps1", "shared/run-local-mcp-hub.ps1", "slash_commands/**"],
      "entrypoints": ["local_mcp_hub.py", "custom_slash_commands_mcp.py", "sqlite_mcp_server.py"],
      "lockfiles": [],
      "distribution": "git_snapshot",
      "required": true,
      "redistribution": {"public_release": false, "authorization": "workspace_source"},
      "materialization": "stage_source_tree_then_run_python_smoke",
      "validation": ["python3 workspace/_bridge/local_mcp_hub.py validate", "python3 workspace/_bridge/mcp_session_doctor.py validate"]
    },
    {
      "id": "codegraph-linux-x64",
      "capabilities": ["codegraph"],
      "implementation_type": "offline_node_bundle",
      "platform": "linux-x64",
      "license": "MIT",
      "source": "${WORK_GIT_ROOT}/workspace/_bridge/tools/codegraph",
      "include": ["package.json", "package-lock.json", "node_modules/**"],
      "entrypoints": ["node_modules/.bin/codegraph"],
      "lockfiles": ["package-lock.json"],
      "distribution": "github_release_asset",
      "required": true,
      "redistribution": {"public_release": true, "authorization": "MIT"},
      "materialization": "download_verify_extract_without_npm_install",
      "validation": ["node node_modules/@colbymchenry/codegraph/lib/dist/bin/codegraph.js --help"]
    },
    {
      "id": "gitnexus-linux-x64",
      "capabilities": ["gitnexus"],
      "implementation_type": "offline_node_bundle",
      "platform": "linux-x64",
      "license": "PolyForm-Noncommercial-1.0.0",
      "source": "${CODEX_RESOURCE_DEPENDENCIES}/node/gitnexus/1.6.9",
      "include": ["package.json", "package-lock.json", "node_modules/**"],
      "entrypoints": ["node_modules/.bin/gitnexus"],
      "lockfiles": ["package-lock.json"],
      "distribution": "github_release_asset_authorized_only",
      "required": true,
      "redistribution": {
        "public_release": true,
        "authorization": "user_confirmed_distribution_authorization",
        "authorization_ref": "user instruction 2026-07-20: GitNexus distribution authorized"
      },
      "materialization": "download_verify_extract_without_npm_install",
      "validation": ["node node_modules/gitnexus/dist/cli/index.js --help"],
      "redistribution_note": "user-authorized distribution only; do not treat the PolyForm-Noncommercial license as unrestricted redistribution"
    },
    {
      "id": "graphify-linux-x64",
      "capabilities": ["graphify"],
      "implementation_type": "offline_node_bundle",
      "platform": "linux-x64",
      "license": "MIT",
      "source": "${CODEX_RESOURCE_DEPENDENCIES}/node/graphify/0.17.1",
      "include": ["package.json", "package-lock.json", "node_modules/**"],
      "entrypoints": ["node_modules/.bin/graphify"],
      "lockfiles": ["package-lock.json"],
      "distribution": "github_release_asset",
      "required": true,
      "redistribution": {"public_release": true, "authorization": "MIT"},
      "materialization": "download_verify_extract_without_npm_install",
      "validation": ["node node_modules/@sentropic/graphify/dist/cli.js --help"]
    },
    {
      "id": "mcp-node-filesystem-linux-x64",
      "capabilities": ["filesystem"],
      "implementation_type": "offline_node_bundle",
      "platform": "linux-x64",
      "license": "upstream-package-license",
      "source": "${WORK_GIT_ROOT}/workspace/_bridge/tools/mcp-node",
      "include": ["package.json", "package-lock.json", "node_modules/**"],
      "entrypoints": ["node_modules/@modelcontextprotocol/server-filesystem/dist/index.js"],
      "lockfiles": ["package-lock.json"],
      "distribution": "github_release_asset",
      "required": true,
      "redistribution": {"public_release": true, "authorization": "MIT"},
      "materialization": "download_verify_extract_without_npm_install",
      "validation": ["node node_modules/@modelcontextprotocol/server-filesystem/dist/index.js --help"]
    },
    {
      "id": "node-repl-windows-x64",
      "capabilities": ["node_repl"],
      "implementation_type": "platform_binary",
      "platform": "windows-x64",
      "license": "private_runtime",
      "source": "${WINDOWS_USERPROFILE}/.local/bin",
      "include": ["node_repl.exe"],
      "entrypoints": ["node_repl.exe"],
      "lockfiles": [],
      "distribution": "encrypted_external_archive",
      "required": true,
      "redistribution": {"public_release": false, "authorization": "private_runtime_only"},
      "materialization": "owner_import_then_wsl_bridge_projection",
      "validation": ["node_repl.exe --help"],
      "redistribution_note": "never upload to a public GitHub Release"
    },
    {
      "id": "ddgs-python-windows-x64",
      "capabilities": ["resource-search"],
      "implementation_type": "offline_python_bundle",
      "platform": "windows-x64",
      "license": "upstream-package-license",
      "source": "${WINDOWS_NATIVE_BRIDGE_ROOT}/runtime_dependencies/ddgs/${WINDOWS_SEARCH_RUNTIME_KEY}",
      "include": ["**"],
      "entrypoints": ["ddgs/__init__.py"],
      "lockfiles": [],
      "distribution": "encrypted_external_archive",
      "required": true,
      "redistribution": {"public_release": false, "authorization": "owner_managed_windows_runtime"},
      "materialization": "download_verify_extract_without_pip_install",
      "runtime_layout": "python-abi-and-platform-scoped",
      "runtime_key": "${WINDOWS_SEARCH_RUNTIME_KEY}",
      "runtime_identity_authority": "${WINDOWS_NATIVE_BRIDGE_ROOT}/managed_python_dependency_runtime.py",
      "required_imports": ["ddgs", "lxml.etree"],
      "validation": ["py -3.14 -I ${WINDOWS_NATIVE_BRIDGE_ROOT}/managed_python_dependency_runtime.py select --dependency-root ${WINDOWS_NATIVE_BRIDGE_ROOT}/runtime_dependencies --package ddgs"]
    },
    {
      "id": "remote-mcp-proxies-source",
      "capabilities": ["context7", "openai-docs", "microsoftdocs", "github"],
      "implementation_type": "remote_proxy_source",
      "platform": "linux-x64",
      "license": "workspace-owned-proxy-upstream-service",
      "source": "${WORK_GIT_ROOT}/workspace/_bridge/tools/mcp-wrappers",
      "include": ["*.js", "*.cmd", "*.ps1"],
      "entrypoints": ["context7_stdio_proxy.js", "openai_docs_stdio_proxy.js", "microsoftdocs_stdio_proxy.js"],
      "lockfiles": [],
      "distribution": "git_snapshot",
      "materialization": "stage_proxy_then_reconnect_remote_service",
      "required": true,
      "redistribution": {"public_release": false, "authorization": "workspace_source"},
      "validation": ["node --check context7_stdio_proxy.js", "MCP tools/list after remote reconnect"]
    },
    {
      "id": "enabled-plugin-reacquisition",
      "capabilities": ["plugin-provided-mcp-and-skills"],
      "implementation_type": "plugin_reacquire",
      "platform": "target-platform",
      "license": "mixed-upstream",
      "source": "exports/derived/codex-plugin-inventory.json",
      "include": [],
      "entrypoints": [],
      "lockfiles": [],
      "distribution": "plugin_owner_reacquire",
      "required": true,
      "redistribution": {"public_release": false, "authorization": "owner_reacquire"},
      "materialization": "reacquire_exact_marketplace_revision_then_verify_manifest_hash",
      "validation": ["plugin owner validation", "manifest hash verification"]
    }
  ]
}
